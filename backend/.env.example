SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
SUPABASE_DB_URL=              # direct Postgres connection string (Project Settings > Database > Connection string > URI), for the LangGraph checkpointer
ALLOWED_ORIGINS=http://localhost:3000,https://<your-vercel-app>.vercel.app
